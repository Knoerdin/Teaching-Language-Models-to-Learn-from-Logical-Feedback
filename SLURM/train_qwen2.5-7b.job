#!/bin/bash
#SBATCH --job-name=grpo_qwen25_7b
#SBATCH --output=logs/job_%j.out
#SBATCH --error=logs/job_%j.out
#SBATCH --time=08:00:00
#SBATCH --partition=gpu_h100
#SBATCH --gpus=2
#SBATCH --cpus-per-task=32
#SBATCH --mem=240G

set -euo pipefail

echo "[$(date)] Starting ${SLURM_JOB_NAME:-job} ${SLURM_JOB_ID:-unknown} on $(hostname)"
echo "Submit directory: ${SLURM_SUBMIT_DIR:-unknown}"

module purge
module load 2025

SUBMIT_DIR="${SLURM_SUBMIT_DIR:-$PWD}"
if [ -f "$SUBMIT_DIR/pyproject.toml" ]; then
  PROJECT_DIR="$SUBMIT_DIR"
elif [ -f "$SUBMIT_DIR/../pyproject.toml" ]; then
  PROJECT_DIR="$(cd "$SUBMIT_DIR/.." && pwd)"
else
  echo "Could not find project directory from submit directory: $SUBMIT_DIR"
  echo "Submit from the repo root or the SLURM directory."
  exit 1
fi

echo "Project directory: $PROJECT_DIR"
cd "$PROJECT_DIR"

if [[ "${MASTER_PORT:-}" =~ ^[0-9]+$ ]]; then
  TORCH_MASTER_PORT="$MASTER_PORT"
elif [[ "${SLURM_JOB_ID:-}" =~ ^[0-9]+$ ]]; then
  TORCH_MASTER_PORT=$((20000 + SLURM_JOB_ID % 40000))
else
  TORCH_MASTER_PORT=29501
fi
export MASTER_PORT="$TORCH_MASTER_PORT"

export PATH="$HOME/.local/bin:$PATH"
PYTHON_RUN=(python -u)
TORCH_RUN=(python -m torch.distributed.run --nproc_per_node=2 --master_port="$MASTER_PORT")
if [ -f env/bin/activate ]; then
  echo "Using virtual environment: env"
  source env/bin/activate
elif [ -f .venv/bin/activate ]; then
  echo "Using virtual environment: .venv"
  source .venv/bin/activate
elif command -v uv >/dev/null 2>&1; then
  echo "Using uv: $(command -v uv)"
  uv --version
  PYTHON_RUN=(uv run --frozen python -u)
  TORCH_RUN=(uv run --frozen python -m torch.distributed.run --nproc_per_node=2 --master_port="$MASTER_PORT")
else
  echo "No virtual environment found at env/bin/activate or .venv/bin/activate, and uv is not on PATH."
  echo "From the project directory, create an environment with: uv sync --frozen"
  exit 1
fi

export PYTHONUNBUFFERED=1
export HYDRA_FULL_ERROR=1
export MLFLOW_TRACE_SAMPLING_RATIO="${MLFLOW_TRACE_SAMPLING_RATIO:-0.0}"
export MLFLOW_ENABLE_ASYNC_TRACE_LOGGING="${MLFLOW_ENABLE_ASYNC_TRACE_LOGGING:-false}"

echo "Python command: ${PYTHON_RUN[*]}"
"${PYTHON_RUN[@]}" --version
echo "Torch master port: $MASTER_PORT"

echo "CUDA_VISIBLE_DEVICES=${CUDA_VISIBLE_DEVICES:-unset}"
nvidia-smi
free -h

echo "[$(date)] Launching training"
"${TORCH_RUN[@]}" src/trainer.py \
  TRAINERS@trainer=GRPO_qwen2.5-7b \
  MODELS@model=qwen2.5-7b
echo "[$(date)] Training finished"
