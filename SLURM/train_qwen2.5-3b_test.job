#!/bin/bash
#SBATCH --job-name=grpo_qwen25_3b_test
#SBATCH --output=logs/job_%j.out
#SBATCH --error=logs/job_%j.err
#SBATCH --time=08:00:00
#SBATCH --partition=gpu_h100
#SBATCH --gpus=1
#SBATCH --cpus-per-task=8
#SBATCH --mem=80G

set -euo pipefail

module purge
module load 2025
module load Python

cd /scratch/$USER/Teaching-Language-Models-to-Learn-from-Logical-Feedback
source env/bin/activate

echo "CUDA_VISIBLE_DEVICES=${CUDA_VISIBLE_DEVICES:-unset}"
nvidia-smi
free -h

python src/trainer.py \
  TRAINERS@trainer=tests/GRPO_qwen2.5-3b_test \
  MODELS@model=tests/qwen2.5-3b_test
