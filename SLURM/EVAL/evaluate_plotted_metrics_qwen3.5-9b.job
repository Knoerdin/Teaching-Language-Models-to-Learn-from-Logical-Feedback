#!/bin/bash
#SBATCH --job-name=eval_plotted_qwen35_9b
#SBATCH --output=SLURM/logs/EVAL/job_%j.out
#SBATCH --error=SLURM/logs/EVAL/job_%j.out
#SBATCH --time=04:00:00
#SBATCH --partition=gpu_h100
#SBATCH --gpus=1
#SBATCH --cpus-per-task=16
#SBATCH --mem=180G

set -euo pipefail

module purge
module load 2024
module load Python/3.12.3-GCCcore-13.3.0

SUBMIT_DIR="${SLURM_SUBMIT_DIR:-$PWD}"
PROJECT_DIR="$SUBMIT_DIR"
while [ "$PROJECT_DIR" != "/" ] && [ ! -f "$PROJECT_DIR/pyproject.toml" ]; do
  PROJECT_DIR="$(cd "$PROJECT_DIR/.." && pwd)"
done

if [ ! -f "$PROJECT_DIR/pyproject.toml" ]; then
  echo "Could not find project directory from submit directory: $SUBMIT_DIR"
  echo "Submit from the repo root, SLURM directory, or a SLURM job subdirectory."
  exit 1
fi

cd "$PROJECT_DIR"

OUTPUT_ROOT="${OUTPUT_ROOT:-outputs/final_eval_runs}"
RUN_NAME="${RUN_NAME:-plotted_metrics_${SLURM_JOB_ID:-manual}_$(date +%Y%m%d_%H%M%S)}"
RUN_DIR="${RUN_DIR:-$OUTPUT_ROOT/$RUN_NAME}"
EVAL_DIR="${EVAL_DIR:-$RUN_DIR/evaluation}"
PLOT_DIR="${PLOT_DIR:-$RUN_DIR/plots}"
RUNTIME_LOG_DIR="$RUN_DIR/slurm_logs"
mkdir -p "$EVAL_DIR" "$PLOT_DIR" "$RUNTIME_LOG_DIR"
RUNTIME_LOG="$RUNTIME_LOG_DIR/runtime_${SLURM_JOB_ID:-manual}.log"
exec > >(tee -a "$RUNTIME_LOG") 2>&1

echo "[$(date)] Starting ${SLURM_JOB_NAME:-job} ${SLURM_JOB_ID:-unknown} on $(hostname)"
echo "Submit directory: ${SLURM_SUBMIT_DIR:-unknown}"
echo "Project directory: $PROJECT_DIR"
echo "Run directory: $RUN_DIR"
echo "Runtime log: $RUNTIME_LOG"

EVAL_VENV="${EVAL_VENV:-}"
if [ -z "$EVAL_VENV" ]; then
  for candidate in ".venv_eval" "eval_venv" ".venv"; do
    if [ -f "$candidate/bin/activate" ]; then
      EVAL_VENV="$candidate"
      break
    fi
  done
fi

if [ -z "$EVAL_VENV" ] || [ ! -f "$EVAL_VENV/bin/activate" ]; then
  echo "Could not find an evaluation virtualenv."
  echo "Set EVAL_VENV=/path/to/eval/env when submitting, or create .venv_eval."
  exit 1
fi
echo "Using evaluation environment: $EVAL_VENV"
source "$EVAL_VENV/bin/activate"

python - <<'PY'
import sys

if sys.version_info[:2] != (3, 12):
    raise SystemExit(
        "This evaluation requires Python 3.12, but the active environment uses "
        f"{sys.version.split()[0]}. Recreate the eval environment after loading "
        "Python/3.12.3-GCCcore-13.3.0."
    )
PY

PROJECT_PYTHONPATH="$PROJECT_DIR/src"
AGENT_REASONING_SRC="${AGENT_REASONING_SRC:-}"
if [ -z "$AGENT_REASONING_SRC" ]; then
  for candidate in \
    "$PROJECT_DIR/../agent_reasoning_rl/src" \
    "$PROJECT_DIR/../agent_reasoning_rl" \
    "$PROJECT_DIR/../agent_reasoning_rl/agent_reasoning_rl/src" \
    "$PROJECT_DIR/../agent_reasoning_rl/agent_reasoning_rl"; do
    if [ -d "$candidate/agent_reasoning" ]; then
      AGENT_REASONING_SRC="$candidate"
      break
    fi
  done
fi

if [ -n "$AGENT_REASONING_SRC" ]; then
  if [ ! -d "$AGENT_REASONING_SRC/agent_reasoning" ]; then
    echo "AGENT_REASONING_SRC must point to the directory containing agent_reasoning/."
    echo "Got: $AGENT_REASONING_SRC"
    exit 1
  fi
  PROJECT_PYTHONPATH="$PROJECT_PYTHONPATH:$AGENT_REASONING_SRC"
  export AGENT_REASONING_SRC
  echo "Using agent_reasoning source: $AGENT_REASONING_SRC"
else
  echo "No sibling agent_reasoning source detected; relying on installed package."
fi
export PYTHONPATH="$PROJECT_PYTHONPATH${PYTHONPATH:+:$PYTHONPATH}"

export PYTHONUNBUFFERED=1
export MLFLOW_TRACE_SAMPLING_RATIO="${MLFLOW_TRACE_SAMPLING_RATIO:-0.0}"
export MLFLOW_ENABLE_ASYNC_TRACE_LOGGING="${MLFLOW_ENABLE_ASYNC_TRACE_LOGGING:-false}"
export USE_TF=0
export USE_FLAX=0
export USE_JAX=0
export TRANSFORMERS_NO_TF=1
export TRANSFORMERS_NO_FLAX=1
export TOKENIZERS_PARALLELISM=false
export HF_HUB_DISABLE_TELEMETRY=1
export PYTORCH_CUDA_ALLOC_CONF="${PYTORCH_CUDA_ALLOC_CONF:-expandable_segments:True}"

if [ -z "${VAMPIRE_BIN:-}" ]; then
  for candidate in \
    "$PROJECT_DIR/../vampire-src/vampire" \
    "$PROJECT_DIR/../vampire-src/bin/vampire" \
    "$PROJECT_DIR/../vampire-src/build/vampire" \
    "$PROJECT_DIR/../vampire-src/build/bin/vampire"; do
    if [ -x "$candidate" ]; then
      export VAMPIRE_BIN="$candidate"
      break
    fi
  done
fi

if [ -z "${VAMPIRE_BIN:-}" ] || [ ! -x "$VAMPIRE_BIN" ]; then
  echo "Could not find an executable Vampire binary."
  echo "Set VAMPIRE_BIN=/path/to/vampire when submitting, or build Vampire under ../vampire-src."
  if [ -d "$PROJECT_DIR/../vampire-src" ]; then
    echo "Executable-looking files under ../vampire-src:"
    find "$PROJECT_DIR/../vampire-src" -maxdepth 4 -type f -perm -u=x -print | sort | head -50
  fi
  exit 1
fi
echo "Using Vampire: $VAMPIRE_BIN"

is_model_dir() {
  local candidate="$1"
  [ -f "$candidate/adapter_config.json" ] || [ -f "$candidate/config.json" ]
}

is_local_model_path() {
  local candidate="$1"
  case "$candidate" in
    /*|./*|../*|~/*|outputs/*|checkpoints/*|runs/*|model_artifacts/*)
      return 0
      ;;
  esac
  [ -e "$candidate" ]
}

first_model_path() {
  local fallback="$1"
  local candidate
  local found

  for candidate in "$@"; do
    if is_model_dir "$candidate"; then
      printf '%s\n' "$candidate"
      return
    fi
  done

  for candidate in "$@"; do
    if [ -d "$candidate" ]; then
      found="$(find "$candidate" -maxdepth 4 -type f \( -name adapter_config.json -o -name config.json \) -print -quit 2>/dev/null || true)"
      if [ -n "$found" ]; then
        dirname "$found"
        return
      fi
    fi
  done

  for candidate in "$@"; do
    if [ -e "$candidate" ]; then
      printf '%s\n' "$candidate"
      return
    fi
  done
  printf '%s\n' "$1"
}

sanitize_name() {
  local sanitized
  sanitized="$(printf '%s' "$1" | sed -E 's/[^A-Za-z0-9_.-]+/_/g; s/^[._]+//; s/[._]+$//')"
  printf '%s\n' "${sanitized:-model}"
}

INCLUDE_BASE_MODEL="${INCLUDE_BASE_MODEL:-1}"
BASE_MODEL_NAME="${BASE_MODEL_NAME:-base}"
BASE_MODEL_PATH="${BASE_MODEL_PATH:-Qwen/Qwen3.5-9B}"
SFT_MODEL_NAME="${SFT_MODEL_NAME:-sft}"
SFT_MODEL_PATH="${SFT_MODEL_PATH:-$(first_model_path \
  outputs/sft_qwen3.5-9b/final_20260531_1521_sft/checkpoint-1000 \
  outputs/sft_qwen3.5-9b/final_20260531_1521_sft \
  outputs/sft_qwen3.5-9b/checkpoint-1000)}"
GRPO_MODEL_NAME="${GRPO_MODEL_NAME:-grpo_final}"
GRPO_MODEL_PATH="${GRPO_MODEL_PATH:-$(first_model_path \
  outputs/grpo_qwen3.5-9b/final_20260531_1521_grpo \
  outputs/grpo_qwen3.5-9b/final_20260531_1521_grpo/checkpoint-2000 \
  outputs/grpo_qwen3.5-9b/checkpoint-3000)}"
BASE_PLOT_LABEL="${BASE_PLOT_LABEL:-Qwen3.5-9B base}"
SFT_PLOT_LABEL="${SFT_PLOT_LABEL:-SFT step 1000}"
GRPO_PLOT_LABEL="${GRPO_PLOT_LABEL:-GRPO final}"

DATASET="${DATASET:-DATA/FOLIO/folio_test.jsonl}"
LIMIT="${LIMIT:-}"
BATCH_SIZE="${BATCH_SIZE:-4}"
MAX_NEW_TOKENS="${MAX_NEW_TOKENS:-192}"
MAX_INPUT_TOKENS="${MAX_INPUT_TOKENS:-}"
DEVICE="${DEVICE:-auto}"
TORCH_DTYPE="${TORCH_DTYPE:-auto}"
TEMPERATURE="${TEMPERATURE:-0.0}"
TOP_P="${TOP_P:-1.0}"
REPETITION_PENALTY="${REPETITION_PENALTY:-1.1}"
INCLUDE_GOLD_SCHEMA="${INCLUDE_GOLD_SCHEMA:-0}"
POSTPROCESS="${POSTPROCESS:-0}"
INCLUDE_PROMPT="${INCLUDE_PROMPT:-0}"
WRITE_MODEL_OUTPUTS="${WRITE_MODEL_OUTPUTS:-1}"
MODEL_OUTPUT_EXAMPLES="${MODEL_OUTPUT_EXAMPLES:-0}"
LOG_EVERY="${LOG_EVERY:-25}"
PLOT_DPI="${PLOT_DPI:-300}"

echo "Python: $(command -v python)"
python --version
echo "PYTHONPATH=$PYTHONPATH"
echo "CUDA_VISIBLE_DEVICES=${CUDA_VISIBLE_DEVICES:-unset}"
nvidia-smi
free -h

echo "Checking evaluation environment"
python - <<'PY'
import importlib.metadata as md
import os
from pathlib import Path

agent_source = os.environ.get("AGENT_REASONING_SRC")
if agent_source:
    print("AGENT_REASONING_SRC:", agent_source)
    print("agent_reasoning source exists:", (Path(agent_source) / "agent_reasoning").is_dir())
else:
    print("AGENT_REASONING_SRC: unset")
for package_name in ("antlr4-python3-runtime", "pydantic", "mlflow", "omegaconf"):
    try:
        print(f"{package_name}:", md.version(package_name))
    except md.PackageNotFoundError:
        print(f"{package_name}: not installed")
PY

PYTHONPATH="$PROJECT_PYTHONPATH" python - <<'PY'
from REWARDS.proving import get_solver

solver = get_solver()
print("solver:", type(solver))
PY

MODEL_ARGS=()
MODEL_PATHS=()
PLOT_ARGS=(
  src/plot_evaluation_metrics.py
)

if [ "$INCLUDE_BASE_MODEL" = "1" ]; then
  MODEL_ARGS+=(--model "${BASE_MODEL_NAME}=${BASE_MODEL_PATH}")
  MODEL_PATHS+=("$BASE_MODEL_PATH")
  BASE_PREDICTIONS="$EVAL_DIR/$(sanitize_name "$BASE_MODEL_NAME")_predictions.jsonl"
  PLOT_ARGS+=(--prediction "${BASE_PLOT_LABEL}=${BASE_PREDICTIONS}")
  echo "Including base model: ${BASE_MODEL_NAME}=${BASE_MODEL_PATH}"
fi

MODEL_ARGS+=(--model "${SFT_MODEL_NAME}=${SFT_MODEL_PATH}")
MODEL_ARGS+=(--model "${GRPO_MODEL_NAME}=${GRPO_MODEL_PATH}")
MODEL_PATHS+=("$SFT_MODEL_PATH")
MODEL_PATHS+=("$GRPO_MODEL_PATH")

SFT_PREDICTIONS="$EVAL_DIR/$(sanitize_name "$SFT_MODEL_NAME")_predictions.jsonl"
GRPO_PREDICTIONS="$EVAL_DIR/$(sanitize_name "$GRPO_MODEL_NAME")_predictions.jsonl"
PLOT_ARGS+=(--prediction "${SFT_PLOT_LABEL}=${SFT_PREDICTIONS}")
PLOT_ARGS+=(--prediction "${GRPO_PLOT_LABEL}=${GRPO_PREDICTIONS}")

for model_path in "${MODEL_PATHS[@]}"; do
  if ! is_local_model_path "$model_path"; then
    echo "Assuming remote/base model id: $model_path"
    continue
  fi
  if [ ! -e "$model_path" ]; then
    echo "Model path does not exist: $model_path"
    exit 1
  fi
  if [ ! -f "$model_path/adapter_config.json" ] && [ ! -f "$model_path/config.json" ]; then
    echo "Model path is not a PEFT adapter or full HF model directory: $model_path"
    echo "Expected adapter_config.json or config.json."
    echo "Files under model path:"
    find "$model_path" -maxdepth 1 -type f -printf "%f\n" | sort
    echo "Model-looking directories under outputs:"
    find outputs -maxdepth 6 -type f \( -name adapter_config.json -o -name config.json \) -printf "%h\n" 2>/dev/null | sort -u | head -100
    exit 1
  fi
done

EVAL_ARGS=(
  src/evaluate_plotted_metrics.py
  --dataset "$DATASET"
  "${MODEL_ARGS[@]}"
  --batch-size "$BATCH_SIZE"
  --max-new-tokens "$MAX_NEW_TOKENS"
  --device "$DEVICE"
  --torch-dtype "$TORCH_DTYPE"
  --temperature "$TEMPERATURE"
  --top-p "$TOP_P"
  --repetition-penalty "$REPETITION_PENALTY"
  --output-dir "$EVAL_DIR"
  --log-every "$LOG_EVERY"
)

if [ -n "$LIMIT" ]; then
  EVAL_ARGS+=(--limit "$LIMIT")
fi
if [ -n "$MAX_INPUT_TOKENS" ]; then
  EVAL_ARGS+=(--max-input-tokens "$MAX_INPUT_TOKENS")
fi
if [ "$INCLUDE_GOLD_SCHEMA" = "1" ]; then
  EVAL_ARGS+=(--include-gold-schema)
fi
if [ "$POSTPROCESS" = "1" ]; then
  EVAL_ARGS+=(--postprocess)
fi
if [ "$INCLUDE_PROMPT" = "1" ]; then
  EVAL_ARGS+=(--include-prompt)
fi
if [ "$WRITE_MODEL_OUTPUTS" = "1" ]; then
  EVAL_ARGS+=(--write-model-outputs)
else
  EVAL_ARGS+=(--no-write-model-outputs)
fi
if [ -n "$MODEL_OUTPUT_EXAMPLES" ]; then
  EVAL_ARGS+=(--model-output-examples "$MODEL_OUTPUT_EXAMPLES")
fi

echo "[$(date)] Launching direct plotted-metrics evaluation"
printf 'Command: python -u'
printf ' %q' "${EVAL_ARGS[@]}"
printf '\n'
python -u "${EVAL_ARGS[@]}"

PLOT_ARGS+=(
  --output-dir "$PLOT_DIR"
  --dpi "$PLOT_DPI"
)

echo "[$(date)] Plotting final evaluation metrics"
printf 'Command: python -u'
printf ' %q' "${PLOT_ARGS[@]}"
printf '\n'
python -u "${PLOT_ARGS[@]}"

echo "[$(date)] Final evaluation finished"
echo "Metrics and predictions: $EVAL_DIR"
echo "Plots: $PLOT_DIR"
echo "Runtime log: $RUNTIME_LOG"
