#!/bin/bash
#SBATCH --job-name=eval_plotted_qwen35_smoke
#SBATCH --output=SLURM/logs/EVAL/job_%j.out
#SBATCH --error=SLURM/logs/EVAL/job_%j.out
#SBATCH --time=00:45:00
#SBATCH --partition=gpu_h100
#SBATCH --gpus=1
#SBATCH --cpus-per-task=16
#SBATCH --mem=180G

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export LIMIT="${LIMIT:-8}"
export RUN_NAME="${RUN_NAME:-plotted_metrics_smoke_${SLURM_JOB_ID:-manual}_$(date +%Y%m%d_%H%M%S)}"
export LOG_EVERY="${LOG_EVERY:-1}"

bash "$SCRIPT_DIR/evaluate_plotted_metrics_qwen3.5-9b.job"
